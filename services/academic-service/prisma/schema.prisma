generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SemesterStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SubjectStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Semester {
  id           Int            @id @default(autoincrement())
  name         String
  academicYear String
  startDate    DateTime
  endDate      DateTime
  status       SemesterStatus
  userId       Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subjects Subject[]
}

model Subject {
  id           Int           @id @default(autoincrement())
  code         String
  name         String
  credits      Int
  lecturer     String?
  description  String?
  currentGrade String?
  progress     Int           @default(0)
  status       SubjectStatus
  semesterId   Int
  userId       Int

  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
